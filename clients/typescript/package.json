{
  "name": "zydecodb",
  "version": "0.9.0-beta.1",
  "description": "Official TypeScript/Node driver for ZydecoDB — a MongoDB-style document store without the fluff.",
  "license": "MIT",
  "author": "Dataparade",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "zydecodb",
    "database",
    "document-store",
    "nosql"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dataparade/zydecodb"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
